# .envrc - Hybrid: prefers Nix if available, falls back to manual setup

use_conda() {
    local env_name="${1:-$(basename "$PWD")}"
    eval "$(conda shell.zsh hook 2>/dev/null)"
    if conda env list | grep -q "^${env_name} "; then
        conda activate "$env_name"
        log_status "Activated conda environment: ${env_name}"
    else
        log_error "Conda environment '${env_name}' not found"
        return 1
    fi
}

# Load local overrides first (for secrets, API keys, etc.)
[[ -f .envrc.local ]] && source .envrc.local

# Prefer Nix if flake.nix exists, otherwise use conda
if [[ -f flake.nix ]] && command -v nix &>/dev/null; then
    use flake
else
    use_conda "thoth"
fi

# Ensure we're using the project's node_modules binaries
PATH_add node_modules/.bin

# Log activation
log_status "Thoth Tauri development environment loaded"
log_status "Node: $(node --version 2>/dev/null || echo 'not found')"
log_status "Rust: $(rustc --version 2>/dev/null || echo 'not found')"
log_status "Cargo: $(cargo --version 2>/dev/null || echo 'not found')"
